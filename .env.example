# Optional. Defaults to https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional. Enables Solana transaction activity signals.
HELIUS_API_KEY=your-helius-api-key

# Optional. Enables EVM holder and transfer activity signals.
MORALIS_API_KEY=your-moralis-api-key

# Optional. Enables EVM transfer activity fallback/enrichment.
ALCHEMY_API_KEY=your-alchemy-api-key

# Optional. If unset, RiskLens falls back to local .data/reports JSON storage.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Required for auth (login/register). Same values, exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Required in production. Server-only. Do not expose this in the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Comma-separated Supabase user IDs that get admin/unlimited access.
# ADMIN_USER_IDS=uuid-1,uuid-2

# Optional. PostHog analytics (free tier). Leave blank to disable.
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
