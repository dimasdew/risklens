# Optional. Defaults to https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional. If unset, RiskLens falls back to local .data/reports JSON storage.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional server-only alternative. Do not expose this in the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
